# =============================================================================
# CampusAgent 环境变量配置
# 复制此文件为 .env 并修改其中的值
# =============================================================================

# Ollama 服务地址（如果使用本地 Ollama，一般不用改）
OLLAMA_BASE_URL=http://localhost:11434

# 向量嵌入模型（需先在 Ollama 中 pull）
EMBEDDING_MODEL=bge-m3

# 对话模型（需先在 Ollama 中 pull）
# 推荐：qwen3.5 或 qwen2.5，在 Ollama 中创建 Modelfile 后使用自定义名称
CHAT_MODEL=qwen35-campus

# FastAPI 服务配置
HOST=127.0.0.1
PORT=8000

# Tavily 搜索 API Key（可选，百度搜索降级用）
# 注册地址：https://tavily.com/  每月 1000 次免费
TAVILY_API_KEY=
